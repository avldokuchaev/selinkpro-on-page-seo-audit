{
  "manifest_version": 3,
  "name": "SeLinkPro Lite: On-Page SEO Audit, Status Code & Link Checker",
  "version": "3.4",
  "description": "SEO audit tool: check HTTP status, Meta, Schema, Headings, Link health, and Page Performance. Detect indexation issues instantly.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "SeLinkPro SEO On-Page Analyzer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
